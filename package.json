{
  "name": "sarmat-radio-pult",
  "version": "1.0.0",
  "description": "Пульт управления рацией ЧВК Сармат",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "Sarmat PMC",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "firebase": "^12.14.0"
  },
  "build": {
    "appId": "com.sarmat.radiopult",
    "productName": "Sarmat Radio Pult",
    "directories": {
      "output": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
